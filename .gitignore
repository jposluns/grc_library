# Python bytecode and build artefacts
__pycache__/
*.pyc
*.pyo
*.pyd

# Editor artefacts
.vscode/
.idea/
*.swp
*~

# Local test artefacts
/tmp-test/
.DS_Store

# Linter regression-test fixtures (created and removed per test run).
# The directory exists for fixture isolation; its contents should never
# be committed.
/tests/tmp/

# Machine-local Claude Code session settings (per-machine additionalDirectories /
# permissions overrides the detect-env.py fix lines name); never committed.
.claude/settings.local.json

# Local VM terminal-output mirror (Stop hook; never committed)
claude-output.log
